                <option value="">Pilih layanan...</option>
                <option value="keluarga">Hukum Keluarga</option>
                <option value="perdata">Hukum Perdata</option>
                <option value="riba">Perjanjian Riba</option>
                <option value="lainnya">Lainnya</option>
              </select>
            </div>
            <div class="form-group"><label>Pesan</label><textarea placeholder="Ceritakan masalah hukum Anda..." required></textarea></div>
            <button type="submit" class="form-btn">Kirim Pesan</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
