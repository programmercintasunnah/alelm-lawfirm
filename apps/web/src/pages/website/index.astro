    </div>
  </section>

  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <h2>Tim Pengacara</h2>
        <p>Tim profesional yang siap membantu Anda</p>
      </div>
      <div class="team-grid">
        <div class="team-card">
          <div class="team-photo">A</div>
          <h3>Ahmad Wijaya, S.H., M.H.</h3>
          <p class="position">Managing Partner</p>
