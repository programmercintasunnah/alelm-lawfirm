  <section id="faq" class="section faq">
    <div class="container">
      <div class="section-title">
        <h2>Pertanyaan Umum</h2>
        <p>Temukan jawaban untuk pertanyaan yang sering ditanyakan</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <h3>Bagaimana cara memesan konsultasi hukum?</h3>
          <p>Anda dapat memesan konsultasi melalui tombol WhatsApp, atau menghubungi kami langsung melalui halaman kontak.</p>
