      .nav-links.active { display: flex; }
      .hamburger { display: block; position: absolute; right: 20px; top: 15px; }
      .article-header { padding: 120px 20px 60px; margin-top: 60px; }
      .article-header h1 { font-size: 1.8rem; }
    }
  </style>
