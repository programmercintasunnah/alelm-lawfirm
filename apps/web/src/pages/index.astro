<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alelm Lawfirm - Pilih Package</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --primary: #1a365d; --secondary: #c9a227; --text: #2d3748; --light: #f7fafc; --white: #ffffff; }
    body { font-family: 'Poppins', sans-serif; background: var(--light); min-height: 100vh; display: flex; flex-direction: column; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    
    header { background: var(--primary); color: var(--white); padding: 20px 0; text-align: center; }
    header h1 { font-size: 2rem; margin-bottom: 5px; }
    header p { opacity: 0.8; font-size: 0.9rem; }
    
    .container { max-width: 1000px; margin: 0 auto; padding: 60px 20px; flex: 1; }
    .title { text-align: center; margin-bottom: 50px; }
    .title h2 { font-size: 2.5rem; color: var(--primary); margin-bottom: 15px; }
    .title p { color: #718096; font-size: 1.1rem; }
    
    .packages { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; max-width: 1300px; margin: 0 auto; }
    .card { width: 100%; }
.card-header { padding: 60px 50px; color: var(--white); text-align: center; }
    .card-header h3 { font-size: 2.2rem; margin-bottom: 10px; }
    .card-body { padding: 40px 50px; }
    .card-body ul { font-size: 1.1rem; }
    .card-body li { padding: 14px 0; }
    .card-actions { padding: 0 50px 40px; }
    .btn { padding: 18px 20px; font-size: 1.05rem; }
    .btn-primary { background: var(--primary); color: var(--white); }
    .btn-primary:hover { background: #2d4a7c; }
    .btn-outline { background: transparent; color: var(--text); border: 2px solid #e2e8f0; }
    .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
    
    footer { background: var(--primary); color: var(--white); padding: 30px 0; text-align: center; }
    footer p { opacity: 0.7; font-size: 0.9rem; }
    
    @media (max-width: 900px) {
      .packages { grid-template-columns: 1fr; gap: 30px; max-width: 500px; }
      .title h2 { font-size: 1.75rem; }
    }

    @media (max-width: 480px) {
      .packages { grid-template-columns: 1fr; }
      .card-header { padding: 35px 25px; }
      .card-header h3 { font-size: 1.5rem; }
      .card-body { padding: 25px; }
      .card-actions { padding: 0 25px 25px; }
    }
  </style>
</head>
<body>
  <header>
    <h1>Alelm Lawfirm</h1>
    <p>Pilih package yang sesuai dengan kebutuhan Anda</p>
  </header>

  <main class="container">
    <div class="title">
      <h2>Paket Layanan</h2>
      <p>Website dan dashboard firma hukum profesional</p>
    </div>

    <div class="packages">
      <div class="card card-basic" onclick="window.location.href='/website'">
        <div class="card-header">
          <span class="badge">BASIC</span>
          <h3>Basic</h3>
          <p>Website dengan fitur standar</p>
        </div>
        <div class="card-body">
          <h4>Fitur:</h4>
          <ul>
            <li>Website single-page</li>
            <li>Halaman layanan hukum</li>
            <li>Tentang kami & tim</li>
            <li>FAQ</li>
            <li>Form kontak</li>
            <li>Dashboard CRUD konten</li>
            <li>Kelola layanan & tim</li>
            <li>Booking via WhatsApp</li>
          </ul>
        </div>
        <div class="card-actions">
          <a href="/dashboard" class="btn btn-primary">Buka Dashboard</a>
          <a href="/website/login" class="btn btn-outline">Login</a>
        </div>
      </div>

      <div class="card card-custom" onclick="window.location.href='/website-custom'">
        <div class="card-header">
          <span class="badge">CUSTOM</span>
          <h3>Custom</h3>
          <p>Website dengan fitur lengkap</p>
        </div>
        <div class="card-body">
          <h4>Semua fitur Basic +:</h4>
          <ul>
            <li>Booking online sistem</li>
            <li>Scheduling</li>
            <li>Client portal</li>
            <li>Live chat</li>
            <li>Payment gateway</li>
            <li>Artikel & blog</li>
            <li>Super dashboard</li>
            <li>Tim ahli</li>
          </ul>
        </div>
        <div class="card-actions">
          <a href="/dashboard-custom" class="btn btn-primary">Buka Dashboard</a>
          <a href="/website-custom/login" class="btn btn-outline">Login</a>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 Alelm Lawfirm. All rights reserved.</p>
  </footer>
</body>
</html>