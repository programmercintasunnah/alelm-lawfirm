<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alelm Lawfirm - Pilih Package</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --primary: #1a365d; --secondary: #c9a227; --text: #2d3748; --light: #f7fafc; --white: #ffffff; }
    html { overflow-x: hidden; }
    body { overflow-x: hidden; overflow-y: auto; }
    body { font-family: 'Poppins', sans-serif; background: var(--light); }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    
    .main { width: 100%; padding: 30px 20px; }
    .container { max-width: 1100px; width: 100%; margin: 0 auto; }
    .title { margin-bottom: 35px; text-align: center; }
    .title { margin-bottom: 35px; }
    .title h2 { font-size: 2rem; color: var(--primary); text-align: center; margin-bottom: 8px; }
    .title p { color: #718096; text-align: center; font-size: 1rem; }
    
    .packages { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; max-width: 1100px; margin: 0 auto; }
    
    .card { width: 100%; background: var(--white); border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s; cursor: pointer; }
    .card:hover { transform: translateY(-3px); }
    
    .card-header { padding: 35px 30px; color: var(--white); }
    .card-basic .card-header { background: linear-gradient(135deg, #1a365d, #2d4a7c); }
    .card-custom .card-header { background: linear-gradient(135deg, #1a365d, #0d1f3c); }
    
    .card-header h3 { font-size: 1.8rem; margin-bottom: 8px; }
    .card-header p { opacity: 0.9; font-size: 0.9rem; }
    
    .card-body { padding: 25px 30px; }
    .card-body h4 { color: var(--primary); margin-bottom: 12px; font-size: 0.95rem; }
    .card-body ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 20px; }
    .card-body li { padding: 8px 0; color: #4a5568; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; }
    .card-body li::before { content: ""; width: 5px; height: 5px; background: #38a169; border-radius: 50%; flex-shrink: 0; }
    
    .card-actions { padding: 0 30px 25px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
    .btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 14px 8px; text-align: center; border-radius: 8px; font-weight: 600; font-size: 0.8rem; cursor: pointer; transition: all 0.3s; text-decoration: none; }
    .btn-primary { background: var(--secondary); color: var(--primary); border: none; font-weight: 700; }
    .btn-primary:hover { opacity: 0.85; }
    .btn-outline { background: transparent; color: var(--text); border: 2px solid #e2e8f0; }
    .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
    .btn-gold { background: var(--primary); color: var(--white); border: none; }
    .btn-gold:hover { background: #2d4a7c; }
    
    @media (max-width: 900px) {
      .packages { grid-template-columns: 1fr; gap: 25px; max-width: 500px; margin: 0 auto; }
      .title h2 { font-size: 1.6rem; }
      .title p { font-size: 0.9rem; }
      .card-body ul { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="main">
    <div class="container">
      <div class="title">
        <h2>Paket Layanan</h2>
        <p>Pilih package yang sesuai dengan kebutuhan Anda</p>
      </div>

      <div class="packages">
        <div class="card card-basic" onclick="window.location.href='/website'">
          <div class="card-header">
            <h3>Basic</h3>
            <p>Website dengan fitur standar</p>
          </div>
          <div class="card-body">
            <h4>Fitur:</h4>
            <ul>
              <li>Website single-page</li>
              <li>Halaman layanan hukum</li>
              <li>Tentang kami & tim</li>
              <li>FAQ</li>
              <li>Form kontak</li>
              <li>Dashboard CRUD konten</li>
              <li>Kelola layanan & tim</li>
              <li>Booking via WhatsApp</li>
            </ul>
          </div>
          <div class="card-actions">
            <a href="/website" class="btn btn-gold">Lihat Website</a>
            <a href="/dashboard" class="btn btn-primary">Buka Dashboard</a>
            <a href="/website/login" class="btn btn-outline">Login</a>
          </div>
        </div>

        <div class="card card-custom" onclick="window.location.href='/website-custom'">
          <div class="card-header">
            <h3>Custom</h3>
            <p>Website dengan fitur lengkap</p>
          </div>
          <div class="card-body">
            <h4>Semua fitur Basic +:</h4>
            <ul>
              <li>Booking online sistem</li>
              <li>Scheduling</li>
              <li>Client portal</li>
              <li>Live chat</li>
              <li>Payment gateway</li>
              <li>Artikel & blog</li>
              <li>Super dashboard</li>
              <li>Tim ahli</li>
            </ul>
          </div>
          <div class="card-actions">
            <a href="/website-custom" class="btn btn-gold">Lihat Website</a>
            <a href="/dashboard-custom" class="btn btn-primary">Buka Dashboard</a>
            <a href="/website-custom/login" class="btn btn-outline">Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>