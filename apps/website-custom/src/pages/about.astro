      <div class="team-grid">
        <div class="team-card">
          <div class="team-photo">👨‍⚖️</div>
          <h3>Ahmad Wijaya, S.H., M.H.</h3>
          <p class="position">Managing Partner</p>
        </div>
        <div class="team-card">
          <div class="team-photo">👩‍⚖️</div>
          <h3>Siti Rahayu, S.H.</h3>
          <p class="position">Senior Associate</p>
        </div>
        <div class="team-card">
          <div class="team-photo">👨‍⚖️</div>
          <h3>Budi Santoso, S.H., LL.M.</h3>
          <p class="position">Associate</p>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div><h3>雷法学院</h3><p>Jl. Sudirman No. 123</p><p>Jakarta Selatan</p></div>
        <div><h3>Kontak</h3><p>📞 +62 812 3456 7890</p><p>✉️ info@lawfirm.co.id</p></div>
      </div>
      <div class="footer-bottom"><p>&copy; 2026 雷法学院. All rights reserved.</p></div>
    </div>
  </footer>
</body>
</html>